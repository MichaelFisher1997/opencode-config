{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "instructions": [
    "rules/package-manager.md",
    "rules/solid.md"
  ],
  "autoshare": false,
  "autoupdate": true,
  "snapshot": true,
  "watcher": {
    "ignore": [
      ".git",
      ".git/**",
      "node_modules/**",
      "worktree/**",
      ".local/share/opencode/worktree/**",
      ".local/share/opencode/snapshot/**",
      ".local/share/opencode/tool-output/**",
      "zig-cache/**",
      ".zig-cache/**",
      "target/**",
      "dist/**",
      "build/**",
      "**/node_modules/**",
      "**/.git/**",
      "**/worktree/**",
      "**/.local/share/opencode/worktree/**",
      "**/.local/share/opencode/snapshot/**",
      "**/.local/share/opencode/tool-output/**",
      "**/zig-cache/**",
      "**/.zig-cache/**",
      "**/target/**",
      "**/dist/**",
      "**/build/**"
    ]
  },
  "permission": {
    "bash": {
      "gh pr create *": "ask",
      "gh pr comment *": "ask",
      "gh pr edit *": "ask",
      "gh issue create *": "ask",
      "gh issue comment *": "ask",
      "gh issue edit *": "ask",
      "gh issue close *": "ask",
      //"git branch *": "ask",
      //"git checkout -b *": "ask",
      "git switch -c *": "ask"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "provider": {
    "zhipuai": {
      "api": "https://api.z.ai/api/coding/paas/v4"
    }
  }
}
