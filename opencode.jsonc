{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai/glm-5.2",
  "small_model": "openai/gpt-5.4-mini",
  "instructions": [
    "rules/package-manager.md",
    "rules/solid.md"
  ],
  "autoshare": false,
  "autoupdate": true,
  "snapshot": true,
  "watcher": {
    "ignore": [
      ".git",
      ".git/**",
      "node_modules/**",
      "worktree/**",
      ".local/share/opencode/worktree/**",
      ".local/share/opencode/snapshot/**",
      ".local/share/opencode/tool-output/**",
      "zig-cache/**",
      ".zig-cache/**",
      "target/**",
      "dist/**",
      "build/**",
      "**/node_modules/**",
      "**/.git/**",
      "**/worktree/**",
      "**/.local/share/opencode/worktree/**",
      "**/.local/share/opencode/snapshot/**",
      "**/.local/share/opencode/tool-output/**",
      "**/zig-cache/**",
      "**/.zig-cache/**",
      "**/target/**",
      "**/dist/**",
      "**/build/**"
    ]
  },
  "permission": {
    "bash": {
      "gh pr create *": "ask",
      "gh pr comment *": "ask",
      "gh pr edit *": "ask",
      "gh issue create *": "ask",
      "gh issue comment *": "ask",
      "gh issue edit *": "ask",
      "gh issue close *": "ask",
      //"git branch *": "ask",
      //"git checkout -b *": "ask",
      "git switch -c *": "ask"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "provider": {
    "zai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zhipu AI Coding Plan",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "apiKey": "{env:ZAI_API_KEY}",
        "headers": {
          "Authorization": "Bearer {env:ZAI_API_KEY}"
        }
      },
      "models": {
        "glm-5.2": {
          "name": "GLM-5.2",
          "reasoning": true,
          "tool_call": true,
          "modalities": { "input": ["text"] },
          "cost": {
            "input": 0,
            "output": 0,
            "cache_read": 0,
            "cache_write": 0
          },
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        }
      }
    }
  }
}
