{
  "$schema": "https://opencode.ai/config.json",
  "model": "zhipuai-coding-plan/glm-5",
  "small_model": "zhipuai-coding-plan/glm-4.7-flash",
  "instructions": [
    "rules/package-manager.md",
    "rules/solid.md"
  ],
  "autoshare": false,
  "autoupdate": true,
  "permission": {
    "bash": {
      "gh pr create *": "ask",
      "gh pr comment *": "ask",
      "gh pr edit *": "ask",
      "gh issue create *": "ask",
      "gh issue comment *": "ask",
      "gh issue edit *": "ask",
      "gh issue close *": "ask",
      "git branch *": "ask",
      "git checkout -b *": "ask",
      "git switch -c *": "ask"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "kernel": {
      "type": "remote",
      "url": "https://mcp.onkernel.com/mcp"
    }
  },
  "provider": {
    "zhipuai": {
      "api": "https://api.z.ai/api/coding/paas/v4"
    }
  }
}
